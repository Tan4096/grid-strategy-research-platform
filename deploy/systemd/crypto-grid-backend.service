[Unit]
Description=Crypto Grid Backtest Backend
After=network.target

[Service]
Type=simple
User=CHANGE_ME
Group=CHANGE_ME
WorkingDirectory=/opt/crypto-grid/backend
EnvironmentFile=/opt/crypto-grid/.env
ExecStart=/usr/bin/env sh -lc '/opt/crypto-grid/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port ${BACKEND_PORT} --workers ${BACKEND_WORKERS}'
Restart=always
RestartSec=3
KillSignal=SIGINT
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
